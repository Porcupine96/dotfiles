#!/usr/bin/env bash
set -euo pipefail

mono="$HOME/work/mono"

cd "$mono"

name=$(git worktree list --porcelain \
  | grep "^worktree $mono/" \
  | sed "s|^worktree $mono/||" \
  | fzf --prompt="Select worktree: ") || exit 0

if [ -z "$name" ]; then
  exit 0
fi

worktree_path="$mono/$name"

if tmux has-session -t "=$name" 2>/dev/null; then
  tmux switch-client -t "=$name"
else
  tmux new-session -d -s "$name" -c "$worktree_path" -e "HUSKY=0"
  tmux switch-client -t "$name"
fi
